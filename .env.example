# Deployed GolazoPool (set after running golazo-contracts deploy)
NEXT_PUBLIC_GOLAZO_POOL=0x...
# Circles (CRC) ERC-20 the pool settles in
NEXT_PUBLIC_CRC_TOKEN=0x...
# Public origin of this app (used to build invite links)
NEXT_PUBLIC_APP_URL=https://golazo.vercel.app
# Optional RPC override
NEXT_PUBLIC_GNOSIS_RPC=https://rpc.gnosischain.com
